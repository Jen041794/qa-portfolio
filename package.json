{
  "name": "qa-portfolio",
  "version": "1.0.0",
  "description": "QA Automation Testing Portfolio",
  "scripts": {
    "start": "ts-node src/app.ts",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:api": "jest tests/api",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}
